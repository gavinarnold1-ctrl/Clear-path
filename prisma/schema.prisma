// Prisma schema for Oversikt budgeting app
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  CASH
  MORTGAGE
  AUTO_LOAN
  STUDENT_LOAN
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum BudgetTier {
  FIXED
  FLEXIBLE
  ANNUAL
}

enum PropertyType {
  PERSONAL
  RENTAL
  BUSINESS
}

enum TaxSchedule {
  SCHEDULE_A
  SCHEDULE_E
  SCHEDULE_C
}

enum DebtType {
  MORTGAGE
  STUDENT_LOAN
  AUTO
  CREDIT_CARD
  PERSONAL_LOAN
  OTHER
}

enum CardTier {
  BASIC
  MID
  PREMIUM
  ULTRA_PREMIUM
}

enum BenefitRefreshCycle {
  MONTHLY
  QUARTERLY
  ANNUALLY
  CALENDAR_YEAR
  CARDMEMBER_YEAR
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  name                String?
  password            String // hashed — never store plaintext
  refreshTokenVersion Int      @default(0) // Incremented on refresh token rotation to invalidate old tokens
  tosAcceptedAt       DateTime? // Timestamp when user accepted Terms of Service and Privacy Policy
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  profile           UserProfile?
  accounts          Account[]
  transactions      Transaction[]
  budgets           Budget[]
  categories        Category[]
  insights          Insight[]
  insightFeedback   InsightFeedback[]
  efficiencyScores  EfficiencyScore[]
  annualExpenses    AnnualExpense[]
  householdMembers  HouseholdMember[]
  properties        Property[]
  propertyGroups    PropertyGroup[]
  debts             Debt[]
  monthlySnapshots  MonthlySnapshot[]
  categoryMappings  UserCategoryMapping[]
  userCards          UserCard[]
}

model Account {
  id              String      @id @default(cuid())
  name            String
  type            AccountType
  balance         Float       @default(0)
  startingBalance Float       @default(0)  // R1.5b: User-entered baseline balance
  balanceAsOfDate DateTime?                // R1.5b: Date the baseline was set; transactions after this adjust balance
  currency        String      @default("USD")
  institution     String?                  // Bank/provider name (e.g., "Chase", "Fidelity")
  isManual        Boolean     @default(true) // true = user-created, false = Plaid-connected
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Plaid fields (only populated for Plaid-connected accounts)
  plaidAccountId    String?   // Plaid's account_id
  plaidItemId       String?   // Plaid's item_id (groups accounts from same bank)
  plaidAccessToken  String?   // R11.5: Stored encrypted with AES-256-GCM (iv:authTag:ciphertext format)
  plaidCursor       String?   // Cursor for transaction sync pagination
  plaidLastSynced   DateTime? // Last successful sync timestamp

  // Forecast engine — asset classification
  assetClass        String?   // 'cash' | 'high_yield_savings' | 'bonds' | 'index_fund' | 'mutual_fund' | 'individual_stock' | 'crypto' | 'real_estate' | 'other'
  expectedReturn    Float?    // User override for annual return rate (decimal, e.g. 0.045 for 4.5%). Null = use asset class default
  riskWeightOverride Float?   // User override for risk weight (0.0–1.0). Null = use asset class default

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId      String?       // R3.2a: Account owner — default person tag for transactions
  owner        HouseholdMember? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  transactions  Transaction[]
  debt          Debt?         // One-to-one: auto-populated debt for loan/credit accounts
  propertyLinks AccountPropertyLink[]
  userCard      UserCard?     // One-to-one: identified card program

  @@index([ownerId])
  @@index([plaidItemId])
}

model Category {
  id             String      @id @default(cuid())
  type           String      // "income" | "expense" | "transfer"
  group          String      // Parent group name (e.g., "Food & Dining", "Housing")
  name           String      // Specific category (e.g., "Groceries", "Mortgage")
  icon           String?     // Emoji icon
  budgetTier     BudgetTier? // Default budget tier for this expense category
  isDefault      Boolean     @default(true)
  isActive       Boolean     @default(true)
  isTaxRelevant  Boolean     @default(false) // Flag for tax-related categories
  scheduleECategory String?  // Schedule E line item (for rental property)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  userId       String?       // null = system default, set = user custom
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  budgets          Budget[]
  debts            Debt[]
  categoryMappings UserCategoryMapping[]

  @@unique([userId, type, group, name])
  @@index([type])
  @@index([userId])
}

model Transaction {
  id                String   @id @default(cuid())
  date              DateTime
  merchant          String   // Cleaned merchant name (Monarch "Merchant" column)
  amount            Float    // ALWAYS: negative = money out, positive = money in
  classification    String   @default("expense") // "income" | "expense" | "transfer"
  transactionType   String?  // "debit" or "credit" (from Monarch CSV, optional)
  originalStatement String?  // Raw bank description before cleanup
  originalCategory  String?  // Raw category name from CSV import (preserved for reference)
  notes             String?  // User-added notes
  tags              String?  // Comma-separated tags (e.g., "tax,business")
  importSource      String?  // "csv" | "manual" | "plaid"
  plaidTransactionId String?  @unique // Plaid's transaction_id — prevents duplicate imports
  isPending         Boolean  @default(false) // true for Plaid pending transactions (not yet posted)
  pendingPlaidId    String?  // Links a posted transaction to its former pending plaidTransactionId
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  categoryId          String?
  category            Category?         @relation(fields: [categoryId], references: [id])
  accountId           String?
  account             Account?          @relation(fields: [accountId], references: [id])
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  annualExpenseId     String?
  annualExpense       AnnualExpense?    @relation(fields: [annualExpenseId], references: [id], onDelete: SetNull)
  householdMemberId   String?
  householdMember     HouseholdMember?  @relation(fields: [householdMemberId], references: [id], onDelete: SetNull)
  propertyId          String?
  property            Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  debtId              String?           // R5.8: Link payment transactions to a debt
  debt                Debt?             @relation(fields: [debtId], references: [id], onDelete: SetNull)
  splits              TransactionSplit[]

  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, classification])
  @@index([userId, merchant])
  @@index([userId, date, amount])
  @@index([userId, accountId])
  @@index([userId, householdMemberId])
  @@index([userId, propertyId])
  @@index([userId, annualExpenseId])
  @@index([accountId])
  @@index([annualExpenseId])
  @@index([householdMemberId])
  @@index([propertyId])
  @@index([debtId])
}

model Budget {
  id        String    @id @default(cuid())
  name      String
  amount    Float // target spend / save limit
  period    BudgetPeriod
  tier      BudgetTier   @default(FLEXIBLE)
  startDate DateTime
  endDate   DateTime? // null = rolling / no end
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // FIXED tier fields
  isAutoPay     Boolean? // Is this bill auto-paid?
  dueDay        Int?     // Day of month bill is due (1-31)
  varianceLimit Float?   // Max acceptable deviation from expected amount

  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  annualExpense AnnualExpense?

  @@index([userId, tier])
}

model AnnualExpense {
  id              String   @id @default(cuid())
  budgetId        String   @unique
  budget          Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  name            String   // "Summer vacation", "New couch"
  annualAmount    Float    // Estimated annual cost
  dueMonth        Int      // 1-12 target month
  dueYear         Int      // Target year
  isRecurring     Boolean  @default(false)
  monthlySetAside Float    // Stored: (annualAmount - funded) / monthsRemaining
  funded          Float    @default(0)
  status          String   @default("planned") // "planned" | "funded" | "spent" | "overspent"
  actualCost      Float?
  actualDate      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, dueYear, dueMonth])
  @@index([budgetId])
}

model Insight {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      String // "spending", "debt", "savings", "tax", "subscription"
  type          String // "waste", "optimization", "alert", "opportunity"
  priority      String // "high", "medium", "low"
  title         String
  description   String
  savingsAmount Float? // Estimated dollar savings (monthly)
  actionItems   String // JSON array of action steps
  status        String    @default("active") // "active", "dismissed", "completed"
  metadata      String? // JSON blob for additional context
  generatedAt   DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Feedback fields
  dismissReason   String? // "not_relevant", "already_doing", "too_hard", "disagree", "other"
  completionNotes String? // User notes when marking as completed
  contextSnapshot String? // JSON snapshot of budget/temporal context at generation time

  feedback InsightFeedback[]

  @@index([userId, status])
  @@index([userId, category])
}

model InsightFeedback {
  id        String   @id @default(cuid())
  insightId String
  insight   Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int? // 1-5 star rating
  helpful   Boolean? // Quick thumbs up/down
  comment   String? // Free-form text
  createdAt DateTime @default(now())

  @@unique([insightId, userId])
  @@index([userId])
}

model EfficiencyScore {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  overallScore  Float // 0-100
  spendingScore Float // 0-100
  savingsScore  Float // 0-100
  debtScore     Float // 0-100
  period        String // "2026-02" (year-month)
  breakdown     String // JSON with detailed scoring
  createdAt     DateTime @default(now())

  @@unique([userId, period])
  @@index([userId])
}

// ─── Onboarding & Profile ─────────────────────────────────────────────────────

model UserProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Onboarding state
  onboardingCompleted   Boolean   @default(false)
  onboardingCompletedAt DateTime?
  onboardingStep        Int       @default(0) // 0-3: tracks how far the user got

  // Q1: Financial Goal
  primaryGoal           String?   // "save_more" | "spend_smarter" | "pay_off_debt" | "gain_visibility" | "build_wealth"
  goalSetAt             DateTime? // When current goal was selected
  previousGoals         Json?     // Array of {goal, setAt, changedAt} for goal change history

  // Q2: Household Structure
  householdType         String?   // "single" | "shared_partner" | "separate_partner" | "family"

  // Q3: Income Range
  incomeRange           String?   // "under_50k" | "50k_100k" | "100k_150k" | "150k_200k" | "200k_300k" | "over_300k"

  // Legacy fields (kept for backward compatibility, no longer set during onboarding)
  hasRentalProperty     Boolean   @default(false)
  debtLevel             String?   // "minimal" | "credit_cards" | "student_loans" | "multiple"
  categoryMode          String?   // "recommended" | "custom" | "import_match"

  // Budget settings
  expectedMonthlyIncome Float?    // User-set expected monthly income for budgets page

  // Concrete goal target (proposed by AI, confirmed/adjusted by user)
  goalTarget            Json?     // GoalTarget shape — see src/types/index.ts

  // In-progress answers not yet materialized into records (JSON)
  pendingSetup          String?   // JSON: { partnerName? }

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model HouseholdMember {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  accounts     Account[]     // R3.2a: Accounts owned by this person

  @@index([userId])
}

model Property {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         PropertyType  @default(PERSONAL)
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  // Address fields
  address      String?
  city         String?
  state        String?
  zipCode      String?

  // Tax schedule (auto-set based on type: PERSONAL→SCHEDULE_A, RENTAL→SCHEDULE_E, BUSINESS→SCHEDULE_C)
  taxSchedule  TaxSchedule?

  // Depreciation tracking (primarily for RENTAL properties)
  purchasePrice      Decimal?  @db.Decimal(12, 2)
  purchaseDate       DateTime?
  buildingValuePct   Decimal?  @db.Decimal(5, 2)  // e.g. 80.00 means 80% of purchase price is building
  priorDepreciation  Decimal?  @db.Decimal(12, 2)

  // Financial details (for mortgage-bearing properties)
  currentValue       Float?
  loanBalance        Float?
  monthlyPayment     Float?
  interestRate       Float?      // Annual rate as decimal (e.g., 0.0485 for 4.85%)
  loanTermMonths     Int?        // Original term (e.g., 360 for 30-year)
  loanStartDate      DateTime?

  // Forecast engine — appreciation
  appreciationRate   Float?    @default(0.03) // Annual appreciation rate (decimal). Default 3%

  // Escrow breakdown (monthly amounts)
  monthlyPropertyTax Float?
  monthlyInsurance   Float?
  monthlyHOA         Float?
  monthlyPMI         Float?

  // Property group membership
  groupId      String?
  group        PropertyGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  splitPct     Decimal?      @db.Decimal(5, 2)  // Default allocation % within the group (0.00-100.00)

  // Existing relationships
  transactions      Transaction[]
  debts             Debt[]
  accountLinks      AccountPropertyLink[]
  splitAllocations  SplitRule[]
  transactionSplits TransactionSplit[] @relation("TransactionSplitProperty")
  categoryMappings  UserCategoryMapping[]

  @@index([userId])
  @@index([groupId])
}

// ─── Property Groups & Transaction Splits ────────────────────────────────────

model PropertyGroup {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  properties  Property[]
  splitRules  SplitRule[]
  matchRules  SplitMatchRule[]

  @@unique([userId, name])
  @@index([userId])
}

model SplitRule {
  id              String   @id @default(cuid())
  propertyGroupId String
  propertyGroup   PropertyGroup @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  allocationPct   Decimal  @db.Decimal(5, 2)  // 0.00-100.00 — all rules in a group must sum to 100
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@unique([propertyGroupId, propertyId])
  @@index([propertyGroupId])
  @@index([propertyId])
}

model SplitMatchRule {
  id              String        @id @default(cuid())
  propertyGroupId String
  propertyGroup   PropertyGroup @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  name            String
  matchField      String        // "merchant" | "category" | "description"
  matchPattern    String
  allocations     Json          // Array<{ propertyId: string; percentage: number }>
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt

  @@unique([propertyGroupId, name])
  @@index([propertyGroupId])
}

model TransactionSplit {
  id            String   @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property @relation("TransactionSplitProperty", fields: [propertyId], references: [id], onDelete: Cascade)
  amount        Float    // Allocated portion of the parent transaction
  createdAt     DateTime @default(now())

  @@unique([transactionId, propertyId])
  @@index([transactionId])
  @@index([propertyId])
}

model AccountPropertyLink {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([accountId, propertyId])
  @@index([accountId])
  @@index([propertyId])
}

// ─── Smart Category Learning ─────────────────────────────────────────────────

model UserCategoryMapping {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantName String   // Normalized: lowercase, trimmed
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  confidence   Float    @default(1.0) // 1.0 = explicit user reclassification
  timesApplied Int      @default(0)   // Incremented each time the mapping is auto-applied
  // Multi-signal matching fields
  direction    String?  // "credit" or "debit" — null means match both
  amountMin    Float?   // Minimum amount range — null means no floor
  amountMax    Float?   // Maximum amount range — null means no ceiling
  descKeywords String?  // Comma-separated keywords from description — null means ignore
  propertyId   String?  // Optional: scope mapping to a specific property
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, merchantName, direction, categoryId])
  @@index([userId])
  @@index([propertyId])
}

// ─── Debts ──────────────────────────────────────────────────────────────────

model Debt {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  type            DebtType
  currentBalance  Float
  originalBalance Float?
  interestRate    Float
  minimumPayment  Float
  escrowAmount    Float?    // Optional: monthly taxes + insurance for mortgages
  paymentDay      Int?
  termMonths      Int?
  startDate       DateTime?
  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id])
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  accountId       String?   @unique // Links Debt to a Plaid-connected Account (one debt per account)
  account         Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  transactions    Transaction[] // R5.8: Payment transactions linked to this debt

  @@index([userId])
}

// ─── Monthly Snapshots ─────────────────────────────────────────────────────

model MonthlySnapshot {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month             DateTime // first day of the month (e.g. 2026-02-01)
  trueRemaining     Float
  totalIncome       Float
  totalExpenses     Float
  savingsRate       Float
  netSurplus        Float
  annualFundedPct   Float
  budgetsOnTrack    Int
  budgetsTotal      Int
  fixedPaid         Int
  fixedTotal        Int
  flexOverBudget    Int
  transactionCount  Int
  avgDailySpend     Float
  totalDebt         Float?
  totalDebtPayments Float?
  debtPaidDown      Float?
  netWorth          Float?
  personBreakdown   String?  // JSON: { [name]: amount }
  propertyBreakdown String?  // JSON: { [name]: amount }
  reviewHeadline    String?
  reviewBody        String?
  efficiencyScore   Int?
  spendingScore     Int?
  savingsScore      Int?
  debtScore         Int?
  createdAt         DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

// ─── Credit Card Programs & Benefits ────────────────────────────────────────

model CardProgram {
  id              String    @id @default(cuid())
  issuer          String    // "Chase", "American Express", "Capital One"
  name            String    // "Sapphire Preferred", "Gold Card"
  tier            CardTier
  annualFee       Float     @default(0)
  rewardsCurrency String?   // "Ultimate Rewards", "Membership Rewards", "Miles"
  signUpBonus     String?   // "60,000 points after $4,000 in 3 months"
  foreignTxFee    Float     @default(0) // e.g. 0.03 = 3%
  isActive        Boolean   @default(true) // Card still available to apply for

  // Plaid matching hints
  plaidPatterns   Json?     // Array of patterns: ["sapphire preferred", "chase sapphire"]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  benefits        CardBenefit[]
  userCards       UserCard[]

  @@unique([issuer, name])
  @@index([issuer])
}

model CardBenefit {
  id              String    @id @default(cuid())
  cardProgramId   String
  cardProgram     CardProgram @relation(fields: [cardProgramId], references: [id], onDelete: Cascade)

  name            String    // "Dining Rewards", "Travel Credit"
  type            String    // "cashback" | "points_multiplier" | "statement_credit" | "insurance" | "perk"
  category        String?   // Spending category this applies to: "Dining", "Travel", "Groceries", etc.

  // Reward details
  rewardRate      Float?    // e.g. 0.03 = 3% back or 3x points
  rewardUnit      String?   // "percent" | "points_per_dollar"
  maxReward       Float?    // Annual cap on this benefit (dollars or points)

  // Statement credit details
  creditAmount    Float?    // e.g. 300 for $300 travel credit
  creditCycle     BenefitRefreshCycle? // When the credit resets

  // Merchant matching for outgoing charges
  eligibleMerchants      Json?     // String[]: ["uber", "uber eats"]
  merchantMatchType      String    @default("contains") // "contains" | "exact" | "startsWith"

  // Merchant matching for incoming credits (perk reimbursements)
  creditMerchantPatterns Json?     // String[]: ["amex uber", "uber cash credit"]. Falls back to eligibleMerchants if empty.

  // Whether this benefit's utilization can be tracked via transactions
  isTransactionTrackable Boolean   @default(false)

  description     String    // Human-readable: "3x points on dining worldwide"
  terms           String?   // Fine print / conditions
  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  userCardBenefits UserCardBenefit[]

  @@index([cardProgramId])
  @@index([type])
}

model UserCard {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardProgramId   String
  cardProgram     CardProgram @relation(fields: [cardProgramId], references: [id], onDelete: Cascade)
  accountId       String?   @unique // Links to user's Account (one card program per account)
  account         Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  nickname        String?   // User's label: "My daily card"
  lastFourDigits  String?   // "4242"
  openedDate      DateTime? // When the card was opened
  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  benefits        UserCardBenefit[]

  @@unique([userId, cardProgramId])
  @@index([userId])
  @@index([accountId])
}

model UserCardBenefit {
  id              String    @id @default(cuid())
  userCardId      String
  userCard        UserCard  @relation(fields: [userCardId], references: [id], onDelete: Cascade)
  cardBenefitId   String
  cardBenefit     CardBenefit @relation(fields: [cardBenefitId], references: [id], onDelete: Cascade)

  // Tracking usage of credits/perks
  usedAmount      Float     @default(0) // How much of a credit has been used
  lastResetDate   DateTime? // When the credit last reset
  isOptedIn       Boolean   @default(true) // User can opt out of tracking a benefit
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  @@unique([userCardId, cardBenefitId])
  @@index([userCardId])
}

// ─── Reference Databases ────────────────────────────────────────────────────
// Read-only datasets that power AI recommendations.
// Not user-generated — shipped with the app and maintained annually.

// ─── Tax Rules Database ─────────────────────────────────────────────────────

model TaxRule {
  id          String   @id @default(cuid())

  // Identity
  ruleCode    String   @unique @map("rule_code")  // e.g., 'SCHED_E_REPAIRS', 'SEC_199A'
  title       String                               // human-readable name
  description String                               // plain-English explanation

  // Classification
  taxYear      Int      @map("tax_year")            // 2025, 2026, etc.
  jurisdiction String                               // 'federal', 'CT', 'NY', etc.
  form         String?                              // 'Schedule E', 'Schedule A', '1040'
  formLine     String?  @map("form_line")           // 'Line 14', 'Line 8a'
  category     String                               // DEDUCTIONS_RENTAL, CREDITS, etc.
  subcategory  String?

  // Applicability (stored as JSON arrays)
  appliesTo     Json    @default("[]") @map("applies_to")      // ["homeowner", "landlord", ...]
  propertyTypes Json    @default("[]") @map("property_types")  // ["primary_residence", "rental"]
  filingStatuses Json   @default("[]") @map("filing_statuses") // ["single", "mfj", ...]

  // Limits & Thresholds
  annualLimit         Float?  @map("annual_limit")
  incomePhaseOutStart Float?  @map("income_phase_out_start")
  incomePhaseOutEnd   Float?  @map("income_phase_out_end")
  percentageLimit     Float?  @map("percentage_limit")       // e.g., 0.075 for 7.5% AGI floor

  // Metadata
  ircSection     String?   @map("irc_section")     // IRC Section: '163', '199A'
  sourceUrl      String?   @map("source_url")
  effectiveDate  DateTime? @map("effective_date")
  expirationDate DateTime? @map("expiration_date")
  lastVerified   DateTime  @map("last_verified")
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  thresholds              TaxRuleThreshold[]
  deductionCategoryMappings DeductionCategoryMapping[]

  @@index([taxYear])
  @@index([category])
  @@index([form])
  @@map("tax_rules")
}

model TaxRuleThreshold {
  id        String @id @default(cuid())
  taxRuleId String @map("tax_rule_id")
  taxRule   TaxRule @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)

  filingStatus   String  @map("filing_status")   // 'single', 'mfj', etc.
  bracketFloor   Float   @map("bracket_floor")
  bracketCeiling Float?  @map("bracket_ceiling") // NULL for top bracket
  rate           Float?                           // tax rate or phase-out rate
  flatAmount     Float?  @map("flat_amount")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([taxRuleId])
  @@map("tax_rule_thresholds")
}

model DeductionCategoryMapping {
  id String @id @default(cuid())

  // App category (matches the categories table)
  spendingCategory String  @map("spending_category")  // 'Rental Repairs', 'Mortgage'
  propertyType     String? @map("property_type")       // 'personal', 'rental', NULL

  // Tax destination
  taxRuleId         String? @map("tax_rule_id")
  taxRule           TaxRule? @relation(fields: [taxRuleId], references: [id])
  form              String                              // 'Schedule E', 'Schedule A'
  formLine          String? @map("form_line")
  scheduleECategory String? @map("schedule_e_category") // 'Repairs', 'Insurance', etc.

  // Allocation rules
  allocationMethod    String? @map("allocation_method")      // 'full', 'sqft_split', 'usage_split'
  defaultAllocationPct Float? @map("default_allocation_pct") // e.g., 0.50
  allocationNotes     String? @map("allocation_notes")

  // Conditions
  requiresReceipt    Boolean @default(false) @map("requires_receipt")
  minAmountThreshold Float?  @map("min_amount_threshold")
  maxDeductible      Float?  @map("max_deductible")

  taxYear   Int      @map("tax_year")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([spendingCategory])
  @@index([taxYear])
  @@map("deduction_category_mappings")
}

model TaxCalendar {
  id String @id @default(cuid())

  taxYear     Int      @map("tax_year")
  eventName   String   @map("event_name")       // "Q4 Estimated Tax Payment Due"
  eventDate   DateTime @map("event_date")
  eventType   String   @map("event_type")        // 'deadline', 'opportunity', 'reminder'
  description String?
  appliesTo   Json     @default("[]") @map("applies_to") // ["landlord", "self_employed"]
  actionRequired String? @map("action_required")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([taxYear])
  @@index([eventDate])
  @@map("tax_calendar")
}

// ─── Consumer Spending Benchmark Database ───────────────────────────────────

model SpendingBenchmark {
  id String @id @default(cuid())

  // Time period
  surveyYear Int @map("survey_year")

  // Segment dimensions
  incomeRangeLow  Float?  @map("income_range_low")
  incomeRangeHigh Float?  @map("income_range_high")
  incomeQuintile  Int?    @map("income_quintile")   // 1-5
  householdSize   Int?    @map("household_size")
  region          String?                            // 'northeast', 'midwest', 'south', 'west', 'all'
  ageRangeLow     Int?    @map("age_range_low")
  ageRangeHigh    Int?    @map("age_range_high")
  housingTenure   String? @map("housing_tenure")     // 'owner', 'renter', 'all'

  // Spending data
  category    String                                 // BLS major category
  subcategory String?                                // BLS subcategory
  appCategory String? @map("app_category")           // mapped to app's category names

  annualMean   Float  @map("annual_mean")
  monthlyMean  Float  @map("monthly_mean")           // annual_mean / 12
  annualMedian Float? @map("annual_median")
  shareOfTotal Float? @map("share_of_total")         // e.g., 0.127 = 12.7%

  // Sample info
  sampleSize Int? @map("sample_size")

  // Metadata
  source      String  @default("BLS Consumer Expenditure Survey")
  sourceTable String? @map("source_table")           // e.g., 'Table 1101'
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([incomeRangeLow, incomeRangeHigh])
  @@index([region])
  @@index([category])
  @@index([appCategory])
  @@map("spending_benchmarks")
}

model SpendingCategoryCrosswalk {
  id String @id @default(cuid())

  blsCategory    String  @map("bls_category")     // "Food at home"
  blsSubcategory String? @map("bls_subcategory")  // "Cereals and bakery products"
  appCategory    String  @map("app_category")      // "Groceries"

  mappingConfidence String? @map("mapping_confidence") // 'exact', 'approximate', 'partial'
  notes             String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("spending_category_crosswalk")
}

model IncomeBenchmark {
  id String @id @default(cuid())

  surveyYear    Int    @map("survey_year")
  metric        String                             // 'median_household_income', etc.
  region        String?                            // 'northeast', 'CT', 'all'
  householdType String? @map("household_type")     // 'all', 'married_couple', 'single'

  value  Float
  source String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("income_benchmarks")
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("landing")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("waitlist_entries")
}
