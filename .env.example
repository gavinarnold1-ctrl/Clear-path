# Copy this file to .env and fill in real values
# Never commit .env to version control

# Database
# Local dev (SQLite): DATABASE_URL="file:./dev.db" and omit DIRECT_URL
# Production (Neon): use the pooled connection string for DATABASE_URL
#   and the direct (non-pooled) connection string for DIRECT_URL
DATABASE_URL="postgres://<user>:<password>@<pooler-host>.neon.tech/<dbname>?sslmode=require"
DIRECT_URL="postgres://<user>:<password>@<direct-host>.neon.tech/<dbname>?sslmode=require"

# Session secret — must be at least 32 characters
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-strong-random-secret-min-32-chars"
